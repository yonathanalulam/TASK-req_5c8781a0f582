PORT=4000
MONGO_URI=mongodb://localhost:27017/offline_ops_portal
# JWT_SECRET: generate a strong random secret (≥32 chars). Example:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=24
ARGON2_MEMORY_KIB=19456
ARGON2_ITERATIONS=2
ARGON2_PARALLELISM=1
# ENCRYPTION_KEY_V1_HEX: 32 random bytes as 64 hex chars. Example:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY_V1_HEX=
CURRENT_KEY_VERSION=1
ATTACHMENT_DIR=./storage/attachments
EXPORT_DIR=./storage/exports
TIMEZONE=America/New_York
CORS_ORIGIN=http://localhost:5173
SEED_ADMIN_USERNAME=admin
# Change SEED_ADMIN_PASSWORD on first boot. Must pass the password policy (≥12 chars).
SEED_ADMIN_PASSWORD=
